# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/acme_salary_db

# Backend
NODE_ENV=development
PORT=3000

# Authentication
JWT_SECRET=your-secret-key-min-32-characters-for-hs256-signing

# Logging Configuration
# LOG_LEVEL: debug, info, warn, error (default: info)
LOG_LEVEL=debug

# LOG_FORMAT: json (production), text (development - human readable)
LOG_FORMAT=text

# Frontend
VITE_API_URL=http://localhost:3000

# Monitoring Integration (Optional - uncomment to enable)
# SENTRY_DSN=https://your-key@sentry.io/project-id
# DATADOG_API_KEY=your-datadog-key
# NEW_RELIC_LICENSE_KEY=your-newrelic-key

# Deployment Configuration (Required for production)
# DEPLOY_HOST=your-production-server-ip
# DEPLOY_USER=deploy-user
# DEPLOY_SSH_KEY=your-private-key-content
